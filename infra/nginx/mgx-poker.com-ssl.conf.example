# HTTPS-enabled nginx config for mgx-poker.com.
# Requires certificates provisioned by certbot (or similar) under /etc/letsencrypt/live/mgx-poker.com/.
# The HTTP-only template remains in infra/nginx/mgx-poker.com.conf.example.

upstream mgx_backend {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name mgx-poker.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name mgx-poker.com;

    ssl_certificate /etc/letsencrypt/live/mgx-poker.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mgx-poker.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/mgx-poker;
    index index.html;

    access_log /var/log/nginx/mgx-poker.access.log;
    error_log  /var/log/nginx/mgx-poker.error.log;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://mgx_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /healthz {
        proxy_pass http://mgx_backend/health;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
