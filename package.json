{
  "name": "badugi-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:game:progress": "vitest run src/games/testing/progress src/games/testing/regression src/games/testing/scenario",
    "test:game:known-bugs": "vitest run src/games/testing/regression/gameProgressKnownBugs.test.js",
    "test:game:family": "vitest run src/games/testing/scenario/*FamilyProgress.test.js",
    "test:game:stud": "vitest run src/games/testing/scenario/studFamilyProgress.test.js",
    "test:game:flop": "vitest run src/games/testing/scenario/flopFamilyProgress.test.js",
    "test:game:draw-family": "vitest run src/games/testing/scenario/drawFamilyProgress.test.js",
    "test:game:chinese": "vitest run src/games/testing/scenario/chineseFamilyProgress.test.js",
    "test:game:one-hand": "vitest run src/games/testing/scenario/allVariantsOneHandProgression.test.js src/games/testing/scenario/familyOneHandProgression.test.js",
    "test:rl:pipeline": "vitest run src/rl/__tests__/rlDataPipelineAudit.test.js src/rl/__tests__/badugiObservationSchema.test.js src/rl/__tests__/drawObservationSchema.test.js src/ai/__tests__/onnxPolicyAdapter.test.js src/ai/__tests__/onnxPolicyAdapterInference.test.js src/ai/__tests__/modelRouter.test.js",
    "test:e2e:progress": "playwright test tests/e2e/mgx-game-progress.spec.js --project=badugi-flow",
    "test:e2e:progression": "playwright test tests/e2e/mgx-game-progression.spec.js --project=badugi-flow",
    "test:scrape": "python -m tests.scraping.runner smoke",
    "variants:export": "node --experimental-json-modules scripts/exportVariants.mjs",
    "ai:verify-models": "node scripts/verifyAiModelAssets.mjs",
    "ai:install-models": "node scripts/installAiModelAssets.mjs",
    "ai:build-bootstrap-models": "node scripts/runPythonTool.mjs src/rl/training/build_badugi_bootstrap_onnx.py",
    "ai:build-draw-bootstrap-models": "node scripts/runPythonTool.mjs src/rl/training/build_draw_bootstrap_onnx.py",
    "ai:evaluate-draw-onnx": "node scripts/runPythonTool.mjs src/rl/training/evaluate_draw_onnx.py",
    "ai:train-badugi": "node scripts/runPythonTool.mjs src/rl/training/train_dqn.py",
    "ai:export-badugi-onnx": "node scripts/runPythonTool.mjs src/rl/training/export_badugi_dqn_onnx.py",
    "ai:evaluate-badugi-onnx": "node scripts/runPythonTool.mjs src/rl/training/evaluate_badugi_onnx.py",
    "ai:gate-badugi-model": "node scripts/runPythonTool.mjs src/rl/training/gate_badugi_model.py",
    "ai:benchmark-badugi-human-practice": "node scripts/runPythonTool.mjs src/rl/training/benchmark_badugi_human_practice.py",
    "ai:evaluate-badugi-checkpoints": "node scripts/runPythonTool.mjs src/rl/training/evaluate_badugi_checkpoints.py",
    "ai:train-draw": "node scripts/runPythonTool.mjs src/rl/training/train_draw_dqn.py",
    "ai:export-draw-onnx": "node scripts/runPythonTool.mjs src/rl/training/export_draw_dqn_onnx.py",
    "ai:train-board": "node scripts/runPythonTool.mjs src/rl/training/train_board_dqn.py",
    "ai:export-board-onnx": "node scripts/runPythonTool.mjs src/rl/training/export_board_dqn_onnx.py",
    "ai:evaluate-board-onnx": "node scripts/runPythonTool.mjs src/rl/training/evaluate_board_onnx.py",
    "ai:train-stud": "node scripts/runPythonTool.mjs src/rl/training/train_stud_dqn.py",
    "ai:export-stud-onnx": "node scripts/runPythonTool.mjs src/rl/training/export_stud_dqn_onnx.py",
    "ai:evaluate-stud-onnx": "node scripts/runPythonTool.mjs src/rl/training/evaluate_stud_onnx.py",
    "ai:benchmark-board-human-practice": "node scripts/runPythonTool.mjs src/rl/training/benchmark_board_human_practice.py"
  },
  "dependencies": {
    "onnxruntime-web": "^1.18.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "@testing-library/react": "^14.0.0",
    "jsdom": "^23.0.0",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4",
    "vite": "^7.1.7",
    "vitest": "^4.0.9"
  }
}
